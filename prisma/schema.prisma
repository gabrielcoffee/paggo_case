// Paggo collections tool - schema
// See CLAUDE.md for architecture overview.

generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  // engineType "client" = WASM query compiler + driver adapter, no native
  // query-engine binary at runtime, so serverless (Vercel/Netlify) never hits
  // "engine not found".
  runtime    = "nodejs"
  engineType = "client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Segment {
  SMB
  MID
  ENT
}

enum PaymentMethod {
  BOLETO
  PIX
  CREDIT_CARD
  BANK_TRANSFER
}

enum InvoiceStatus {
  open
  in_negotiation
  agreement_signed
  paid
  written_off
  disputed
}

enum PaymentStatus {
  unpaid
  partial
  paid
}

enum FollowUpStatus {
  pending
  done
  missed
}

enum AgentPlanStatus {
  pending
  confirmed
  executed
  failed
  rejected
}

model Customer {
  id          String   @id
  name        String
  segment     Segment
  creditLimit Decimal  @db.Decimal(14, 2)
  createdAt   DateTime @default(now())

  invoices Invoice[]
}

model Invoice {
  id                           String        @id
  customerId                   String
  issueDate                    DateTime      @db.Date
  dueDate                      DateTime      @db.Date
  paidDate                     DateTime?     @db.Date
  amount                       Decimal       @db.Decimal(14, 2)
  amountPaid                   Decimal       @db.Decimal(14, 2)
  paymentMethod                PaymentMethod
  attempts                     Int
  previousLateInvoicesSnapshot Int
  openBalanceSnapshot          Decimal       @db.Decimal(14, 2)

  status        InvoiceStatus @default(open)
  paymentStatus PaymentStatus @default(unpaid)

  riskScore   Int  @default(0)
  riskFactors Json @default("[]")

  updatedAt DateTime @updatedAt

  customer   Customer           @relation(fields: [customerId], references: [id])
  agreements PaymentAgreement[]

  @@index([status])
  @@index([paymentStatus])
  @@index([riskScore])
  @@index([dueDate])
  @@index([customerId])
}

model Note {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  author     String
  body       String
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
}

model PaymentAgreement {
  id                String   @id @default(cuid())
  originalInvoiceId String
  installments      Int
  discountPct       Decimal? @db.Decimal(5, 2)
  feePct            Decimal? @db.Decimal(5, 2)
  createdBy         String
  createdAt         DateTime @default(now())

  originalInvoice Invoice                @relation(fields: [originalInvoiceId], references: [id])
  installmentRows AgreementInstallment[]

  @@index([originalInvoiceId])
}

model AgreementInstallment {
  id                String    @id @default(cuid())
  agreementId       String
  installmentNumber Int
  dueDate           DateTime  @db.Date
  amount            Decimal   @db.Decimal(14, 2)
  status            String    @default("open")
  paidDate          DateTime? @db.Date
  paidAmount        Decimal?  @db.Decimal(14, 2)

  agreement PaymentAgreement @relation(fields: [agreementId], references: [id])

  @@index([agreementId])
}

model FollowUp {
  id         String         @id @default(cuid())
  entityType String
  entityId   String
  dueAt      DateTime
  channel    String
  status     FollowUpStatus @default(pending)
  body       String
  assignee   String?
  createdBy  String
  createdAt  DateTime       @default(now())

  @@index([entityType, entityId])
  @@index([dueAt])
}

model AuditEvent {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  origin     String
  actor      String
  payload    Json
  timestamp  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([timestamp])
}

model AgentPlan {
  id         String          @id @default(cuid())
  sessionId  String
  summary    String
  steps      Json
  status     AgentPlanStatus @default(pending)
  result     Json?
  createdAt  DateTime        @default(now())
  executedAt DateTime?

  @@index([sessionId])
  @@index([status])
}

model Chat {
  id        String   @id @default(cuid())
  userId    String
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages ChatMessage[]

  @@index([userId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  chatId    String
  role      String
  content   String   @db.Text
  data      Json?
  createdAt DateTime @default(now())

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
}

// Scheduled rule: periodically check a condition over invoices/customers and run
// an effect (note, follow-up, status change, or emailed report). condition/effect
// are stored as JSON validated by zod (src/lib/automation/automation-spec.ts).
model AutomationRule {
  id         String   @id @default(cuid())
  name       String
  enabled    Boolean  @default(true)
  target     String // "invoice" | "customer"
  condition  Json
  effect     Json
  frequency  String // "daily" | "weekly" | "monthly"
  startDate  DateTime @db.Date
  timeOfDay  String // "HH:mm"
  weekday    Int? // 0-6 for weekly
  dayOfMonth Int? // 1-31 for monthly
  nextRunAt  DateTime
  lastRunAt  DateTime?
  createdBy  String
  createdAt  DateTime @default(now())

  runs AutomationRun[]

  @@index([enabled, nextRunAt])
}

model AutomationRun {
  id           String   @id @default(cuid())
  automationId String
  runAt        DateTime @default(now())
  trigger      String // "manual" | "scheduled"
  status       String // "success" | "failed" | "skipped"
  matched      Int
  acted        Int
  summary      String
  detail       Json?

  automation AutomationRule @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([automationId])
}
